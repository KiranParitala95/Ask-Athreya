# Copy this file to ".env" and fill in your real values. The .env file is
# gitignored, so your key never gets committed.

# --- Primary: Groq (recommended — reliable tool-calling, free tier) ---
# Get your key at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here
# Optional: override the model (default: llama-3.3-70b-versatile)
# GROQ_MODEL=llama-3.3-70b-versatile

# --- Fallback Option: OpenAI (best tool-calling reliability) ---
# Get your key at https://platform.openai.com
# OPENAI_API_KEY=your_openai_api_key_here
# OPENAI_MODEL=gpt-4o-mini

# --- Fallback Option: Gemini (experimental with agents) ---
# Get your key at https://aistudio.google.com
# GOOGLE_API_KEY=your_google_api_key_here
# GEMINI_MODEL=gemini-2.0-flash

# Priority order when multiple keys are present: Groq → OpenAI → Gemini
